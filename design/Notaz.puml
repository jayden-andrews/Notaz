@startuml

' =========================
' DOMAIN MODELS
' =========================

class User {
  +Long id
  +String username
  +int streak
  +int totalScore
}

class Lesson {
  +Long id
  +String title
  +String explanation
  +String clefFocus
}

class Question {
  +Long id
  +String note
  +String clef
  +String correctAnswer
  +List<String> options
}

class Attempt {
  +Long id
  +boolean isCorrect
  +String selectedAnswer
  +LocalDateTime timestamp
}

' =========================
' CONTROLLERS
' =========================

class UserController {
  +getProgress()
}

class LessonController {
  +getLessons()
}

class QuestionController {
  +getRandomQuestion()
  +submitAnswer()
}

' =========================
' SERVICES
' =========================

class UserService {
  +getProgress()
}

class LessonService {
  +getLessons()
}

class QuestionService {
  +getRandomQuestion()
  +validateAnswer()
}

' =========================
' REPOSITORIES
' =========================

class UserRepository
class LessonRepository
class QuestionRepository
class AttemptRepository

' =========================
' RELATIONSHIPS
' =========================

' Controller → Service
UserController --> UserService
LessonController --> LessonService
QuestionController --> QuestionService

' Service → Repository
UserService --> UserRepository
LessonService --> LessonRepository
QuestionService --> QuestionRepository
QuestionService --> AttemptRepository

' Domain relationships
Lesson --> Question
User --> Attempt
Question --> Attempt

@enduml